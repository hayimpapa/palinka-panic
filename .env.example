# Pálinka Panic — global leaderboard (optional).
#
# Copy to `.env` and fill in from your Supabase project
# (Project Settings → API). Without these, the game still runs and keeps the
# high score in localStorage only; the online leaderboard is simply hidden.
#
# Only the PUBLIC anon key belongs here. The service-role key is never needed —
# the SQL functions in supabase/schema.sql do the privileged work server-side.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
