# Pálinka Panic — global leaderboard (optional).
#
# Copy to `.env` and fill in from your Supabase project
# (Project Settings → API). Without these, the game still runs and keeps the
# high score in localStorage only; the online leaderboard is simply hidden.
#
# Only the PUBLIC anon key belongs here. NEVER put the service-role key in the
# frontend — it lives exclusively as an Edge Function secret (see supabase/README.md).

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
